#!/bin/bash
# ADR-0006 + ADR-0005: Valida il formato del commit message.
# Aggiornato in CHG-2026-04-29-002:
#   - Classifier dei file in staging (B2): se file non-triviali presenti,
#     CHG-ID resta obbligatorio anche con prefisso docs(/chore(/ci(.
#   - ADR-NNNN obbligatorio nel footer (M6).
#   - CHG-ID citato deve esistere come file in docs/changes/ (M7).

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE" 2>/dev/null || echo "")

# Bypass: merge commits
echo "$COMMIT_MSG" | grep -qE "^Merge " && exit 0

# Bypass: revert commits
echo "$COMMIT_MSG" | grep -qE "^Revert " && exit 0

# Bypass: emergency commits (ADR-0002)
echo "$COMMIT_MSG" | grep -q "\[EMERGENCY-NO-TEST\]" && exit 0

# ── Classifier dei file in staging (allineato a pre-commit) ───────────────────
# Un commit con prefisso docs(/chore(/ci( è ammesso senza CHG-ID SOLO se
# tutti i file in staging sono triviali (.md, docs/, ecc.). Se ci sono
# file applicativi/infrastruttura, CHG-ID è obbligatorio comunque.
STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || echo "")
HAS_NON_TRIVIAL=0
while IFS= read -r f; do
    [ -z "$f" ] && continue
    # Stessa regex di pre-commit per i file triviali
    if ! echo "$f" | grep -qE '(\.md$|^docs/|^\.claude/|^\.gitnexus/|^\.gitignore$|^\.gitattributes$)'; then
        HAS_NON_TRIVIAL=1
        break
    fi
done <<< "$STAGED"

# Bypass: commit triviali (docs, chore, ci) SOLO se nessun file non-triviale in staging
if [ "$HAS_NON_TRIVIAL" -eq 0 ]; then
    echo "$COMMIT_MSG" | grep -qE "^(docs|chore|ci)(\(|:)" && exit 0
fi

# ── Verifica CHG-ID (ADR-0005) ────────────────────────────────────────────────
CHG_MATCH=$(echo "$COMMIT_MSG" | grep -oE "CHG-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{3}" | head -1)
if [ -z "$CHG_MATCH" ]; then
    echo ""
    echo "ERROR: COMMIT BLOCCATO — ADR-0005 (CHG-ID mancante)"
    echo "──────────────────────────────────────────────────────"
    if [ "$HAS_NON_TRIVIAL" -eq 1 ]; then
        echo "Il commit modifica file non-triviali. CHG-ID obbligatorio"
        echo "anche con prefisso docs(/chore(/ci( (CHG-2026-04-29-002, B2)."
    else
        echo "Il commit message non contiene un riferimento CHG-ID."
    fi
    echo ""
    echo "Formato richiesto nel footer:"
    echo "  CHG-YYYY-MM-DD-NNN"
    echo "  ADR-NNNN"
    echo ""
    echo "Esempio completo:"
    echo "  feat(auth): add session token validation"
    echo ""
    echo "  CHG-$(date +%Y-%m-%d)-001"
    echo "  ADR-0002"
    echo ""
    echo "Commit di sola documentazione/manutenzione (NESSUN file"
    echo "non-triviale in staging)? Usa il prefisso:"
    echo "  docs(scope): descrizione"
    echo "  chore(scope): descrizione"
    echo "──────────────────────────────────────────────────────"
    echo ""
    exit 1
fi

# ── Verifica esistenza change document referenziato (M7) ──────────────────────
# Il CHG-ID deve corrispondere a un file in docs/changes/ con prefisso
# YYYY-MM-DD-NNN-*.md. Esempio: CHG-2026-04-29-002 → docs/changes/2026-04-29-002-*.md
CHG_PREFIX=$(echo "$CHG_MATCH" | sed 's/^CHG-//')
CHG_FILE=$(find docs/changes -maxdepth 1 -name "${CHG_PREFIX}-*.md" \
    ! -name "TEMPLATE.md" 2>/dev/null | head -1)

if [ -z "$CHG_FILE" ]; then
    echo ""
    echo "ERROR: COMMIT BLOCCATO — ADR-0005 (CHG-ID inesistente)"
    echo "──────────────────────────────────────────────────────"
    echo "Il commit cita $CHG_MATCH ma nessun file"
    echo "docs/changes/${CHG_PREFIX}-*.md esiste nel repository."
    echo ""
    echo "Soluzione:"
    echo "  1. Verifica il CHG-ID nel commit message."
    echo "  2. Se il change document non esiste ancora, crealo prima"
    echo "     (usa docs/changes/TEMPLATE.md come base)."
    echo "  3. Riprova il commit."
    echo "──────────────────────────────────────────────────────"
    echo ""
    exit 1
fi

# ── Verifica ADR-NNNN (M6) ────────────────────────────────────────────────────
# Almeno un riferimento ADR-NNNN deve essere presente nel footer.
if ! echo "$COMMIT_MSG" | grep -qE "ADR-[0-9]{4}"; then
    echo ""
    echo "ERROR: COMMIT BLOCCATO — ADR-0005 (ADR-NNNN mancante)"
    echo "──────────────────────────────────────────────────────"
    echo "Il commit message non contiene un riferimento ADR-NNNN."
    echo ""
    echo "ADR-0005 richiede entrambi nel footer:"
    echo "  CHG-YYYY-MM-DD-NNN"
    echo "  ADR-NNNN"
    echo ""
    echo "Verificato: $CHG_MATCH presente."
    echo "Mancante: almeno un riferimento ADR-NNNN."
    echo "──────────────────────────────────────────────────────"
    echo ""
    exit 1
fi

exit 0
